{
  "name": "tcc-ebac-qe",
  "version": "1.0.0",
  "private": true,
  "description": "Projeto de TCC em Engenharia de Qualidade de Software com foco no sistema EBAC Shop.",
  "scripts": {
    "test:ui": "npm --prefix automation/UI run test:ui",
    "test:ui:open": "npm --prefix automation/UI run test:ui:open",
    "test:api": "npm --prefix automation/API run test:api",
    "test:api:all": "npm --prefix automation/API run test:api:all",
    "test:api:contracts": "npm --prefix automation/API run test:api:contracts",
    "test:mobile": "npm --prefix automation/Mobile run test",
    "test:mobile:android": "npm --prefix automation/Mobile run test:android",
    "test:mobile:smoke": "npm --prefix automation/Mobile run test:smoke",
    "test:mobile:catalog": "npm --prefix automation/Mobile run test:catalog",
    "test:performance:login": "node -e \"require('fs').mkdirSync('performance/k6/reports',{recursive:true})\" && k6 run --summary-export=performance/k6/reports/login-summary.json performance/k6/login-performance.js",
    "test:performance:catalog": "node -e \"require('fs').mkdirSync('performance/k6/reports',{recursive:true})\" && k6 run --summary-export=performance/k6/reports/catalog-summary.json performance/k6/catalog-performance.js",
    "test:performance": "npm run test:performance:login && npm run test:performance:catalog",
    "square:evaluate": "node tools/square-evaluator.js",
    "square:gate": "node tools/square-evaluator.js --gate",
    "test:all": "npm run test:ui && npm run test:api && npm run test:mobile:smoke && npm run test:performance",
    "ci:ui": "npm run test:ui",
    "ci:api": "npm run test:api",
    "ci:mobile": "npm run test:mobile:smoke",
    "ci:performance": "npm run test:performance"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@types/node": "^25.5.0",
    "@wdio/appium-service": "^9.27.0",
    "@wdio/cli": "^9.27.0",
    "@wdio/globals": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "appium-uiautomator2-driver": "^7.1.0",
    "cypress": "^14.5.4",
    "expect-webdriverio": "^5.6.5",
    "mocha": "^11.7.5",
    "pactum": "^3.9.1"
  }
}
